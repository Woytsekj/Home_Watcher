#include <stdio.h>
#include <string.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "freertos/event_groups.h"
#include "esp_system.h"
#include "esp_wifi.h"
#include "esp_event.h"
#include "esp_log.h"
#include "nvs_flash.h"
#include "mqtt_client.h"
#include "driver/uart.h"
#include "esp_camera.h"

// My secrets file
#include "secrets.h"

// My headers
#include "camera_server.h"

static const char *TAG = "ROBOT_MAIN";

// UART Pins and Settings (Replacing Serial2)
#define TX_PIN (GPIO_NUM_14)
#define RX_PIN (GPIO_NUM_13)
#define UART_NUM UART_NUM_2
#define BUF_SIZE (1024)

// Global MQTT Client Handle
esp_mqtt_client_handle_t mqtt_client;

// --- 1. UART Task (Replaces loop checking Serial2) ---
static void uart_task(void *arg) {
    uint8_t data[BUF_SIZE];
    while (1) {
        // Wait for data from UART
        int len = uart_read_bytes(UART_NUM, data, BUF_SIZE - 1, 20 / portTICK_PERIOD_MS);
        if (len > 0) {
            data[len] = '\0'; // Null-terminate the string
            
            // Trim trailing newline characters (similar to incoming.trim())
            while(len > 0 && (data[len-1] == '\r' || data[len-1] == '\n')) {
                data[len-1] = '\0';
                len--;
            }

            // Check if string starts with "BATT:"
            if (strncmp((char*)data, "BATT:", 5) == 0) {
                char* batteryLevel = (char*)data + 5;
                ESP_LOGI(TAG, "Battery Level: %s", batteryLevel);
                
                // Publish to MQTT
                esp_mqtt_client_publish(mqtt_client, "robotCommands", batteryLevel, 0, 1, 0);
            } else {
                ESP_LOGW(TAG, "Unknown Serial2 Message: %s", data);
            }
        }
    }
}

// --- 2. MQTT Event Handler (Replaces callback & reconnect) ---
static void mqtt_event_handler(void *handler_args, esp_event_base_t base, int32_t event_id, void *event_data) {
    esp_mqtt_event_handle_t event = event_data;
    
    switch ((esp_mqtt_event_id_t)event_id) {
        case MQTT_EVENT_CONNECTED:
            ESP_LOGI(TAG, "MQTT_EVENT_CONNECTED");
            esp_mqtt_client_subscribe(mqtt_client, "robotCommands", 0);
            break;
        case MQTT_EVENT_DISCONNECTED:
            ESP_LOGI(TAG, "MQTT_EVENT_DISCONNECTED");
            // ESP-MQTT handles automatic reconnection natively
            break;
        case MQTT_EVENT_DATA:
            ESP_LOGI(TAG, "MQTT_EVENT_DATA");
            // Replaces your callback()
            char topic[64];
            char message[256];
            snprintf(topic, sizeof(topic), "%.*s", event->topic_len, event->topic);
            snprintf(message, sizeof(message), "%.*s", event->data_len, event->data);
            
            ESP_LOGI(TAG, "MQTT Received: %s", message);
            
            // Forward message + newline to Arduino via UART2
            uart_write_bytes(UART_NUM, message, strlen(message));
            uart_write_bytes(UART_NUM, "\n", 1);
            break;
        default:
            break;
    }
}

// --- 3. WiFi Event Handler ---
static void wifi_event_handler(void* arg, esp_event_base_t event_base, int32_t event_id, void* event_data) {
    if (event_base == WIFI_EVENT && event_id == WIFI_EVENT_STA_START) {
        esp_wifi_connect();
    } else if (event_base == WIFI_EVENT && event_id == WIFI_EVENT_STA_DISCONNECTED) {
        esp_wifi_connect();
        ESP_LOGI(TAG, "Retrying WiFi connection...");
    } else if (event_base == IP_EVENT && event_id == IP_EVENT_STA_GOT_IP) {
        ip_event_got_ip_t* event = (ip_event_got_ip_t*) event_data;
        ESP_LOGI(TAG, "Camera Stream Ready! Go to: http://" IPSTR, IP2STR(&event->ip_info.ip));
    }
}

// --- 4. Main Application ---
void app_main(void) {
    // 1. Initialize NVS (Required for WiFi)
    esp_err_t ret = nvs_flash_init();
    if (ret == ESP_ERR_NVS_NO_FREE_PAGES || ret == ESP_ERR_NVS_NEW_VERSION_FOUND) {
      ESP_ERROR_CHECK(nvs_flash_erase());
      ret = nvs_flash_init();
    }
    ESP_ERROR_CHECK(ret);

    // 2. Initialize UART (Replaces Serial & Serial2)
    uart_config_t uart_config = {
        .baud_rate = 115200,
        .data_bits = UART_DATA_8_BITS,
        .parity    = UART_PARITY_DISABLE,
        .stop_bits = UART_STOP_BITS_1,
        .flow_ctrl = UART_HW_FLOWCTRL_DISABLE,
        .source_clk = UART_SCLK_DEFAULT,
    };
    ESP_ERROR_CHECK(uart_driver_install(UART_NUM, BUF_SIZE * 2, 0, 0, NULL, 0));
    ESP_ERROR_CHECK(uart_param_config(UART_NUM, &uart_config));
    ESP_ERROR_CHECK(uart_set_pin(UART_NUM, TX_PIN, RX_PIN, UART_PIN_NO_CHANGE, UART_PIN_NO_CHANGE));

    // Create a FreeRTOS task to constantly monitor the UART
    xTaskCreate(uart_task, "uart_task", 4096, NULL, 10, NULL);

    // 3. Initialize WiFi
    ESP_ERROR_CHECK(esp_netif_init());
    ESP_ERROR_CHECK(esp_event_loop_create_default());
    esp_netif_create_default_wifi_sta();
    wifi_init_config_t cfg = WIFI_INIT_CONFIG_DEFAULT();
    ESP_ERROR_CHECK(esp_wifi_init(&cfg));

    ESP_ERROR_CHECK(esp_event_handler_instance_register(WIFI_EVENT, ESP_EVENT_ANY_ID, &wifi_event_handler, NULL, NULL));
    ESP_ERROR_CHECK(esp_event_handler_instance_register(IP_EVENT, IP_EVENT_STA_GOT_IP, &wifi_event_handler, NULL, NULL));

    // --- REPLACED SECTION ---
    wifi_config_t wifi_config = {0}; // Zero-initialize the struct safely
    
    // Safely copy the string pointers into the struct arrays
    strncpy((char *)wifi_config.sta.ssid, SECRET_SSID, sizeof(wifi_config.sta.ssid) - 1);
    strncpy((char *)wifi_config.sta.password, SECRET_PASS, sizeof(wifi_config.sta.password) - 1);

    ESP_ERROR_CHECK(esp_wifi_set_mode(WIFI_MODE_STA));
    ESP_ERROR_CHECK(esp_wifi_set_config(WIFI_IF_STA, &wifi_config));
    ESP_ERROR_CHECK(esp_wifi_start());

    // 4. Initialize Camera
    if (init_camera() == ESP_OK) {
        start_camera_server();
        ESP_LOGI(TAG, "Camera initialization and server startup successful.");
    } else {
        ESP_LOGE(TAG, "Failed to initialize camera.");
    }

    // 5. Initialize Secure MQTT
    // Format the URI using your secret server
    char mqtt_uri[128];
    

    #ifdef USE_AWS_IOT
        snprintf(mqtt_uri, sizeof(mqtt_uri), "mqtts://%s", SECRET_MQTT_SERVER);
        esp_mqtt_client_config_t mqtt_cfg = {
            .broker.address.uri = mqtt_uri,
            .broker.address.port = SECRET_MQTT_PORT,
            .broker.verification.certificate = (const char *)ROOT_CA,
            .credentials.username = SECRET_MQTT_USER,
            .credentials.authentication.password = SECRET_MQTT_PASS,
        };
        ESP_LOGI(TAG, "Configured for AWS IoT Secure MQTT");
    #else
        snprintf(mqtt_uri, sizeof(mqtt_uri), "mqtt://%s", SECRET_MQTT_SERVER);
        esp_mqtt_client_config_t mqtt_cfg = {
            .broker.address.uri = mqtt_uri,
            .broker.address.port = SECRET_MQTT_PORT,
            .credentials.username = SECRET_MQTT_USER,
            .credentials.authentication.password = SECRET_MQTT_PASS,
        };
        ESP_LOGI(TAG, "Configured for Local Unencrypted MQTT");
    #endif

    mqtt_client = esp_mqtt_client_init(&mqtt_cfg);
    esp_mqtt_client_register_event(mqtt_client, ESP_EVENT_ANY_ID, mqtt_event_handler, NULL);
    esp_mqtt_client_start(mqtt_client);
}